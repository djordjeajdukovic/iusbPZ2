<UserControl x:Class="NetworkService.Views.MeasurementGraphView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="1100">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Text="Measurement Graph View - G3 grafikoni" FontSize="22" FontWeight="Bold" Margin="8,0,0,8" />

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" MinWidth="560" />
                    <ColumnDefinition Width="1*" MinWidth="330" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}" Margin="0,0,8,0">
                    <DockPanel LastChildFill="True">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Izaberi entitet:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0" />
                            <ComboBox Width="220" ItemsSource="{Binding EntityNames}" SelectedIndex="0" ToolTip="Graf prikazuje poslednjih pet merenja za izabrani entitet" />
                            <TextBlock Text="   Log: vreme + ID + vrednost" VerticalAlignment="Center" Foreground="#6B7280" />
                        </StackPanel>

                        <Canvas Height="420" Background="#FFFFFF" ToolTip="G3: krugovi razlicitog poluprecnika poređani po vremenskoj osi">
                            <Rectangle Width="650" Height="360" Stroke="#9CA3AF" StrokeThickness="1" Fill="#FFFFFF" Canvas.Left="20" Canvas.Top="20" />
                            <Line X1="55" Y1="250" X2="640" Y2="250" Stroke="#111827" StrokeThickness="2" />

                            <Ellipse Width="62" Height="62" Fill="#E5E7EB" Stroke="#16A34A" StrokeThickness="3" Canvas.Left="75" Canvas.Top="219" />
                            <TextBlock Text="9.0" Canvas.Left="96" Canvas.Top="240" FontWeight="SemiBold" />
                            <TextBlock Text="10:20" Canvas.Left="87" Canvas.Top="300" />

                            <Ellipse Width="82" Height="82" Fill="#E5E7EB" Stroke="#16A34A" StrokeThickness="3" Canvas.Left="190" Canvas.Top="209" />
                            <TextBlock Text="12.5" Canvas.Left="215" Canvas.Top="240" FontWeight="SemiBold" />
                            <TextBlock Text="10:21" Canvas.Left="208" Canvas.Top="300" />

                            <Ellipse Width="110" Height="110" Fill="#FEE2E2" Stroke="#DC2626" StrokeThickness="3" Canvas.Left="325" Canvas.Top="195" />
                            <TextBlock Text="17.2" Canvas.Left="363" Canvas.Top="240" FontWeight="SemiBold" />
                            <TextBlock Text="10:22" Canvas.Left="360" Canvas.Top="300" />

                            <Ellipse Width="55" Height="55" Fill="#E5E7EB" Stroke="#16A34A" StrokeThickness="3" Canvas.Left="485" Canvas.Top="223" />
                            <TextBlock Text="7.1" Canvas.Left="503" Canvas.Top="240" FontWeight="SemiBold" />
                            <TextBlock Text="10:23" Canvas.Left="496" Canvas.Top="300" />

                            <Ellipse Width="75" Height="75" Fill="#E5E7EB" Stroke="#16A34A" StrokeThickness="3" Canvas.Left="585" Canvas.Top="213" />
                            <TextBlock Text="11.4" Canvas.Left="608" Canvas.Top="240" FontWeight="SemiBold" />
                            <TextBlock Text="10:24" Canvas.Left="604" Canvas.Top="300" />

                            <TextBlock Text="Veci pritisak = veci poluprecnik kruga" Canvas.Left="35" Canvas.Top="35" Foreground="#6B7280" />
                            <TextBlock Text="Crveno = vrednost van opsega 5-16 MP" Canvas.Left="35" Canvas.Top="55" Foreground="#DC2626" />
                        </Canvas>
                    </DockPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource PanelBorderStyle}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="CG4 dodatni grafikon" />
                        <TextBlock Text="Procenat zastupljenosti tipova entiteta u sistemu" TextWrapping="Wrap" Margin="0,0,0,12" />
                        <Canvas Height="155" Background="#FFFFFF">
                            <Rectangle Width="205" Height="44" Fill="#93C5FD" Stroke="#111827" StrokeThickness="1" Canvas.Left="15" Canvas.Top="55" />
                            <Rectangle Width="85" Height="44" Fill="#BFDBFE" Stroke="#111827" StrokeThickness="1" Canvas.Left="220" Canvas.Top="55" />
                            <TextBlock Text="Kablovski senzor 71%" Canvas.Left="52" Canvas.Top="68" FontWeight="SemiBold" />
                            <TextBlock Text="29%" Canvas.Left="245" Canvas.Top="68" FontWeight="SemiBold" />
                            <TextBlock Text="0%" Canvas.Left="15" Canvas.Top="108" />
                            <TextBlock Text="50%" Canvas.Left="145" Canvas.Top="108" />
                            <TextBlock Text="100%" Canvas.Left="270" Canvas.Top="108" />
                        </Canvas>

                        <Border BorderBrush="#CBD5E1" BorderThickness="1" Background="#F8FAFC" Padding="10" Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock Text="Kablovski senzor: 5 entiteta" />
                                <TextBlock Text="Digitalni manometar: 2 entiteta" />
                                <TextBlock Text="Ukupno: 7 entiteta" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
