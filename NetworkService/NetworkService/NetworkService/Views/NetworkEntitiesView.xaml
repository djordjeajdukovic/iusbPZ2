<UserControl x:Class="NetworkService.Views.NetworkEntitiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="1100">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Text="Network Entities View - T1 pritisak u ventilima" FontSize="22" FontWeight="Bold" Margin="8,0,0,8" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*" />
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="1.1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Style="{StaticResource SectionTitleStyle}" Text="Tabela entiteta" />

                    <Border Grid.Row="1" BorderBrush="#CBD5E1" BorderThickness="1" Padding="8" Margin="0,0,0,10" Background="#F8FAFC">
                        <StackPanel>
                            <TextBlock Text="P1 pretraga" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Content="Naziv" IsChecked="True" Margin="0,0,12,0" ToolTip="Trazi po delu naziva entiteta" />
                                <RadioButton Content="Tip" Margin="0,0,12,0" ToolTip="Trazi po imenu tipa entiteta" />
                                <TextBox Width="180" Text="ventil" ToolTip="Uneti deo naziva ili tipa" />
                                <Button Content="Trazi" ToolTip="Primeni P1 pretragu" />
                                <Button Content="Reset" ToolTip="Vrati prikaz svih elemenata" />
                            </StackPanel>
                            <TextBlock Text="CG4 dodatni filter stanja" FontWeight="SemiBold" Margin="0,10,0,6" />
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Content="Svi" IsChecked="True" Margin="0,0,12,0" />
                                <RadioButton Content="Validni 5-16 MP" Margin="0,0,12,0" />
                                <RadioButton Content="Nevalidni" Margin="0,0,12,0" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <DataGrid Grid.Row="2" ItemsSource="{Binding Entities}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" MinHeight="180" ToolTip="Tabelarni prikaz entiteta i poslednje izmerene vrednosti">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" />
                            <DataGridTextColumn Header="Naziv" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="Tip" Binding="{Binding TypeName}" Width="160" />
                            <DataGridTextColumn Header="Vrednost" Binding="{Binding ValueText}" Width="100" />
                            <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="100" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="Obrisi entitet" ToolTip="Brise entitet koji je oznacen u tabeli; pre brisanja ide potvrda akcije" />
                        <Button Content="Undo" ToolTip="Ponisti poslednju komandu" />
                        <Button Content="Undo All" ToolTip="CG4: ponisti sve do sada izvrsene akcije na ovom prikazu" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource PanelBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Forma za dodavanje" />
                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="ID" />
                    <TextBox Text="5" ToolTip="ID mora biti ceo broj i jedinstven" />
                    <TextBlock Style="{StaticResource ErrorTextStyle}" Text="Poruka ispod polja: ID je obavezan i mora biti jedinstven." />

                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Naziv" />
                    <TextBox Text="Ventil E5" ToolTip="Naziv ne sme biti prazan" />
                    <TextBlock Style="{StaticResource ErrorTextStyle}" Text="Poruka ispod polja: naziv je obavezan." />

                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Tip" />
                    <ComboBox ItemsSource="{Binding Types}" SelectedIndex="0" ToolTip="Tipovi za T1: Kablovski senzor / Digitalni manometar" />
                    <TextBlock Style="{StaticResource ErrorTextStyle}" Text="Poruka ispod polja: tip mora biti izabran." />

                    <Border BorderBrush="#CBD5E1" BorderThickness="1" Margin="0,12" Padding="10" Background="#F8FAFC">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="Tema T1" />
                            <TextBlock Text="Pritisak u ventilima" />
                            <TextBlock Text="Validno: 5 - 16 MP" />
                            <TextBlock Text="Tipovi: Kablovski senzor, Digitalni manometar" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Button Content="Dodaj entitet" HorizontalAlignment="Stretch" ToolTip="Nakon dodavanja automatski se restartuje simulator" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Style="{StaticResource SectionTitleStyle}" Text="History paleta - CG4" />
                    <ListBox ItemsSource="{Binding HistoryItems}" ToolTip="Spisak svih izvrsenih akcija" />
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
